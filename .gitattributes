# Default: detect text vs binary; normalize text to LF on commit.
* text=auto eol=lf

# Data and source files: always LF in the working tree (Java parsers don't
# care, but a Windows checkout that auto-converts to CRLF balloons every
# diff and breaks `git blame`).
*.json       text eol=lf
*.properties text eol=lf
*.java       text eol=lf
*.md         text eol=lf
*.gradle     text eol=lf
*.xml        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.sh         text eol=lf

# Native-shell scripts: keep CRLF so cmd / PowerShell parse them cleanly.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries: never touched.
*.jar  binary
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.zip  binary
